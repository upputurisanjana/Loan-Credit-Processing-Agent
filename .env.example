# .env.example — commit this file; do NOT commit .env
# Copy to .env and fill in real values before running.

# GitHub Models — OpenAI-compatible endpoint authenticated with a GitHub PAT
# Create a PAT at: Settings → Developer settings → Personal access tokens
# Minimum scope: models:read
GITHUB_TOKEN=
GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference

# Models — change these to switch models without touching code
PRIMARY_MODEL=openai/gpt-4o-mini
CHALLENGER_MODEL=meta/llama-3.1-70b-instruct

# Policy — path to the active policy YAML (relative to repo root)
POLICY_PATH=./policy/policy_v1.yaml

# Database — SQLite for Phase 1; swap to postgres:// for production
DATABASE_URL=sqlite:///./audit.db

# Lender identity — shown in adverse action notices sent to declined applicants
# Replace with your actual institution name and contact details
LENDER_NAME=Credit Decisioning Ltd
LENDER_CONTACT=decisions@creditagent.example.com | 0800 123 4567
